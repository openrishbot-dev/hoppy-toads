# Upstash Redis credentials for the global leaderboard (api/scores.js).
# Create a free database at https://upstash.com (or add the Upstash integration from the Vercel
# marketplace, which auto-injects these). Copy the REST URL + token here for local `vercel dev`,
# and add the same two vars in the Vercel project settings for production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Note: Vercel's Upstash marketplace integration injects these as KV_REST_API_URL and
# KV_REST_API_TOKEN instead. api/scores.js accepts either naming, so no renaming is needed.

# Optional: HMAC key for the leaderboard anti-cheat (signed run tokens). If unset, api/scores.js
# automatically reuses the Upstash REST token as the key, so anti-cheat is ON by default wherever a
# leaderboard is configured. Set this only if you want a dedicated, rotatable secret.
HOPPY_SECRET=
