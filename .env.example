# Upstash Redis credentials for the global leaderboard (api/scores.js).
# Create a free database at https://upstash.com (or add the Upstash integration from the Vercel
# marketplace, which auto-injects these). Copy the REST URL + token here for local `vercel dev`,
# and add the same two vars in the Vercel project settings for production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
